{
    "name": "l3aro/rating-star-for-filament",
    "description": "Rating star for filament table column and schemas.",
    "keywords": [
        "l3aro",
        "laravel",
        "filamentphp",
        "filament",
        "filament-plugin",
        "filament-rating-star"
    ],
    "homepage": "https://github.com/l3aro/rating-star-for-filament",
    "support": {
        "issues": "https://github.com/l3aro/rating-star-for-filament/issues",
        "source": "https://github.com/l3aro/rating-star-for-filament"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "l3aro",
            "email": "dgbao1340@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "spatie/laravel-package-tools": "^1.15.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.7|^4.0",
        "pestphp/pest-plugin-arch": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "pestphp/pest-plugin-livewire": "^3.0|^4.0",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "l3aro\\FilamentRatingStar\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "l3aro\\FilamentRatingStar\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "analyse": "phpstan analyse",
        "lint": "pint",
        "refactor": "rector",
        "test": "pest",
        "test:lint": "pint --test",
        "test:refactor": "rector --dry-run"
    },
    "extra": {
        "laravel": {
            "providers": [
                "l3aro\\FilamentRatingStar\\FilamentRatingStarServiceProvider"
            ],
            "aliases": {
                "FilamentRatingStar": "l3aro\\FilamentRatingStar\\Facades\\FilamentRatingStar"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}